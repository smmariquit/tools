{
	"name": "tools",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome lint ./src",
		"test": "vitest",
		"test:ci": "vitest run",
		"typecheck": "tsc --noEmit",
		"agent:verify": "npm run typecheck && npm run test:ci > .agent-log.txt 2>&1 || (cat .agent-log.txt && exit 1)",
		"prepare": "husky"
	},
	"dependencies": {
		"@ducanh2912/next-pwa": "^10.2.9",
		"@types/leaflet": "^1.9.21",
		"@vercel/analytics": "^2.0.1",
		"gray-matter": "^4.0.3",
		"leaflet": "^1.9.4",
		"next": "16.2.6",
		"next-intl": "^4.13.0",
		"next-mdx-remote": "^6.0.0",
		"next-themes": "^0.4.6",
		"posthog-js": "^1.376.4",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-leaflet": "^5.0.0",
		"recharts": "^3.8.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@playwright/test": "^1.60.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6.0.2",
		"@vitest/coverage-v8": "^4.1.7",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.6",
		"typescript": "^5",
		"vitest": "^4.1.7"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx}": [
			"biome check --write"
		]
	}
}
